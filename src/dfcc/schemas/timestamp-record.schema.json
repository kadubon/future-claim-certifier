{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfcc.local/schemas/timestamp-record.schema.json",
  "title": "DFCC TimestampRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["lexical_time", "time_basis_ref", "time_scale", "source"],
  "properties": {
    "lexical_time": { "type": "string", "format": "date-time" },
    "time_basis_ref": { "type": "string", "minLength": 1 },
    "time_scale": { "type": "string", "default": "UTC" },
    "source": { "type": "string", "minLength": 1 },
    "traceability": { "type": ["string", "null"] },
    "uncertainty_ref": { "type": ["string", "null"] },
    "timestamp_policy_ref": { "type": ["string", "null"] }
  }
}
