{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfcc.local/schemas/representation-relation-artifact.schema.json",
  "title": "DFCC RepresentationRelationArtifact",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "bound_ref": {
      "type": "string",
      "pattern": "^(artifact:.+|sha(256|384|512):.+)$"
    }
  },
  "required": ["artifact_id", "relations", "checker_status"],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "checker_status": { "type": "string", "minLength": 1 },
    "relations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation_id", "represented_prefix", "proof_ref"],
        "properties": {
          "relation_id": { "type": "string", "minLength": 1 },
          "operational_prefix": { "type": "array" },
          "represented_prefix": { "type": "array" },
          "proof_ref": { "$ref": "#/$defs/bound_ref" }
        }
      }
    }
  }
}
