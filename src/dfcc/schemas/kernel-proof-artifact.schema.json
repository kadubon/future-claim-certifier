{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfcc.local/schemas/kernel-proof-artifact.schema.json",
  "title": "DFCC KernelProofArtifact",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "bound_ref": {
      "type": "string",
      "pattern": "^(artifact:.+|sha(256|384|512):.+)$"
    },
    "nullable_bound_ref": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/bound_ref" }
      ]
    }
  },
  "required": ["artifact_id", "proof"],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "proof": { "$ref": "kernel-proof.schema.json" },
    "checker_transcript_ref": { "$ref": "#/$defs/nullable_bound_ref" },
    "witness_provenance_refs": { "type": "array", "items": { "$ref": "#/$defs/bound_ref" } },
    "evidence_refs": { "type": "array", "items": { "$ref": "#/$defs/bound_ref" } },
    "reason_refs": { "type": "array", "items": { "type": "string" } },
    "reason_ref_records": {
      "type": "array",
      "items": { "$ref": "reason-ref.schema.json" },
      "default": []
    }
  }
}
