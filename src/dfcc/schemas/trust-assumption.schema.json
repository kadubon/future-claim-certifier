{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfcc.local/schemas/trust-assumption.schema.json",
  "title": "DFCC TrustAssumption",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assumption_id",
    "target",
    "scope",
    "reason_refs",
    "reason_ref_records",
    "obligation_refs",
    "checker_transcript_ref"
  ],
  "properties": {
    "assumption_id": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "reason_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^artifact:.+#/.*$" }
    },
    "reason_ref_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "allOf": [
          { "$ref": "reason-ref.schema.json" },
          {
            "type": "object",
            "required": ["digest"],
            "properties": {
              "source_artifact": { "type": "string", "minLength": 1 },
              "source_path": { "type": "string", "pattern": "^/.+$" },
              "digest": { "type": "string", "pattern": "^sha(256|384|512):.+" }
            }
          }
        ]
      }
    },
    "obligation_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^artifact:.+#/.*$" }
    },
    "checker_transcript_ref": {
      "type": "string",
      "pattern": "^(artifact:.+|sha(256|384|512):.+)$"
    }
  }
}
