{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dfcc.local/schemas/measurement-relation-artifact.schema.json",
  "title": "DFCC MeasurementRelationArtifact",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "bound_ref": {
      "type": "string",
      "pattern": "^(artifact:.+|sha(256|384|512):.+)$"
    }
  },
  "required": ["artifact_id", "relation", "checker_status", "proof_refs"],
  "properties": {
    "artifact_id": { "type": "string", "minLength": 1 },
    "checker_status": { "type": "string", "minLength": 1 },
    "proof_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/bound_ref" }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "calibration_ref", "latency_ref", "dependency_ref", "event_order_ref"],
      "properties": {
        "relation_id": { "type": "string", "minLength": 1 },
        "accepted": { "type": "boolean" },
        "calibration_ref": { "$ref": "#/$defs/bound_ref" },
        "latency_ref": { "$ref": "#/$defs/bound_ref" },
        "dependency_ref": { "$ref": "#/$defs/bound_ref" },
        "event_order_ref": { "$ref": "#/$defs/bound_ref" }
      }
    }
  }
}
